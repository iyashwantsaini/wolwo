# wolwo API keys — local development only.
# Copy this file to ".env.dart-define" and fill in your keys.
# Loaded by: flutter run --dart-define-from-file=.env.dart-define
# Never commit ".env.dart-define" — it is git-ignored.
#
# Get keys here:
#   WALLHAVEN_KEY      https://wallhaven.cc/settings/account   (optional, unlocks NSFW + higher rate limits)
#   PIXABAY_KEY        https://pixabay.com/api/docs/           (free, required to use Pixabay)
#   NASA_KEY           https://api.nasa.gov/                   (free; "DEMO_KEY" works for dev)
#   REDDIT_USER_AGENT  free-form, e.g. "wolwo:v1.0 (by /u/your_handle)"

WALLHAVEN_KEY=
PIXABAY_KEY=
NASA_KEY=DEMO_KEY
REDDIT_USER_AGENT=wolwo:dev (by /u/anonymous)
